# ==========================================
# Knoc Local Environment Variables Template
# ==========================================
# 🚨 [팀원 세팅 가이드]
# 1. 이 파일을 복사해서 이름만 `.env`로 변경하세요.
# 2. 아래 변수들의 값을 본인의 로컬 환경(내 PC)에 맞게 채워 넣으세요.
# 3. 진짜 값이 들어간 `.env` 파일은 .gitignore에 의해 깃허브에 올라가지 않습니다.

# Database (로컬 MySQL 세팅)
DB_USERNAME=root
DB_PASSWORD=여기에_로컬_DB_비밀번호_입력

# Security (JWT)
# 로컬 개발용이므로 아무 문자열이나 길게 입력해도 무방합니다.
JWT_SECRET=knoc-local-dev-secret-key-12345

# GitHub API (나중에 PR 연동할 때 사용할 PAT 토큰)
GITHUB_TOKEN=ghp_여기에_발급받은_토큰_입력